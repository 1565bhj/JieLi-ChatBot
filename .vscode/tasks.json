{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "${workspaceFolder}\\tools\\utils\\make.exe",
            "args": [
                "-f",
                "${workspaceFolder}\\Makefile"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the default target from the root Makefile"
        },
        {
            "label": "Clean Project",
            "type": "shell",
            "command": "${workspaceFolder}\\tools\\utils\\make.exe",
            "args": [
                "-f",
                "${workspaceFolder}\\Makefile",
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Clean the default target from the root Makefile"
        }
    ]
}
